@model BarangayConnect.Models.RequestsPageViewModel
@{
    ViewData["Title"] = "Service Requests";
}

<section class="page-heading page-heading--split">
    <div>
        <p class="eyebrow">Request Desk</p>
        @if (Model.IsAdmin)
        {
            <h1>Track resident concerns and follow-up requests with clearer prioritization</h1>
            <p>This workflow stores resident-service links together with priority and status so follow-up is easier for staff and residents.</p>
        }
        else
        {
            <h1>Submit and monitor your own barangay service requests</h1>
            <p>Your resident account can only create and review request logs that belong to you, keeping request history private and focused.</p>
        }
    </div>
    <div class="page-heading__card">
        <strong>@Model.Requests.Count</strong>
        <span>@(Model.IsAdmin ? "requests in the current log" : "requests in your personal log")</span>
    </div>
</section>

@if (TempData["StatusMessage"] is string message)
{
    <div class="alert alert-success shadow-sm">@message</div>
}

<section class="form-layout">
    <article class="panel-card">
        <div class="panel-header">
            <h2>Submit Request</h2>
            <span class="badge-soft">@(Model.IsAdmin ? "Case intake" : "My request intake")</span>
        </div>
        <form asp-action="Requests" method="post" class="data-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="field-grid">
                @if (Model.IsAdmin)
                {
                    <div>
                        <label asp-for="NewRequest.ResidentId"></label>
                        <select asp-for="NewRequest.ResidentId" asp-items="Model.ResidentOptions" class="form-select">
                            <option value="">Select resident</option>
                        </select>
                        <span asp-validation-for="NewRequest.ResidentId" class="text-danger"></span>
                    </div>
                }
                else
                {
                    <div>
                        <label>Resident</label>
                        <div class="info-field">@(Model.CurrentResident?.FullName ?? "Please complete your resident profile first.")</div>
                        <input asp-for="NewRequest.ResidentId" type="hidden" />
                    </div>
                }
                <div>
                    <label asp-for="NewRequest.ServiceId"></label>
                    <select asp-for="NewRequest.ServiceId" asp-items="Model.ServiceOptions" class="form-select">
                        <option value="">Select service</option>
                    </select>
                    <span asp-validation-for="NewRequest.ServiceId" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="NewRequest.Priority"></label>
                    <select asp-for="NewRequest.Priority" class="form-select">
                        <option>Normal</option>
                        <option>High</option>
                        <option>Urgent</option>
                    </select>
                    <span asp-validation-for="NewRequest.Priority" class="text-danger"></span>
                </div>
                <div class="full-span">
                    <label asp-for="NewRequest.Description"></label>
                    <textarea asp-for="NewRequest.Description" class="form-control" rows="4" placeholder="Describe the request clearly, including deadline or context if needed."></textarea>
                    <span asp-validation-for="NewRequest.Description" class="text-danger"></span>
                </div>
            </div>
            <button type="submit" class="btn btn-civic">Submit Request</button>
        </form>
    </article>

    <article class="panel-card">
        <div class="panel-header">
            <h2>@(Model.IsAdmin ? "Priority Guide" : "Request Guidance")</h2>
            <span class="badge-soft">Helpful feature</span>
        </div>
        <div class="info-list">
            @if (Model.IsAdmin)
            {
                <div><strong>Normal:</strong> Standard service follow-up without a strict deadline.</div>
                <div><strong>High:</strong> Important request that should be reviewed earlier than the regular queue.</div>
                <div><strong>Urgent:</strong> Time-sensitive concern that affects an immediate school, work, or legal requirement.</div>
            }
            else
            {
                <div><strong>Normal:</strong> Routine follow-up such as document status checks or standard barangay inquiries.</div>
                <div><strong>High:</strong> Important concern that should be reviewed earlier than a routine request.</div>
                <div><strong>Urgent:</strong> Time-sensitive concerns tied to work, school, health, or legal deadlines.</div>
            }
        </div>
    </article>

    <article class="panel-card panel-card-wide">
        <div class="panel-header">
            <h2>@(Model.IsAdmin ? "Request Log" : "My Request Log")</h2>
            <span class="badge-soft">@Model.Requests.Count listed</span>
        </div>
        <div class="filter-control filter-control--inline">
            <input type="search" class="form-control" placeholder="@(Model.IsAdmin ? "Search by resident, service, priority, or status..." : "Search by service, priority, or status...")" data-filter-input="#request-table" />
        </div>
        <div class="table-shell">
            <table id="request-table" class="table civic-table">
                <thead>
                    <tr>
                        @if (Model.IsAdmin)
                        {
                            <th>Resident</th>
                        }
                        <th>Service</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Submitted</th>
                        @if (Model.IsAdmin)
                        {
                            <th>Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                @foreach (var request in Model.Requests)
                {
                    <tr data-filter-item data-filter-text="@($"{request.ResidentName} {request.ServiceName} {request.Priority} {request.Status} {request.SubmittedOn:MMM dd yyyy}")">
                        @if (Model.IsAdmin)
                        {
                            <td>@request.ResidentName</td>
                        }
                        <td>@request.ServiceName</td>
                        @if (Model.IsAdmin)
                        {
                            <td>
                                <select name="priority" class="form-select form-select-sm" form="update-request-@request.Id">
                                    <option value="Normal" selected="@(request.Priority == "Normal" ? "selected" : null)">Normal</option>
                                    <option value="High" selected="@(request.Priority == "High" ? "selected" : null)">High</option>
                                    <option value="Urgent" selected="@(request.Priority == "Urgent" ? "selected" : null)">Urgent</option>
                                </select>
                            </td>
                            <td>
                                <select name="status" class="form-select form-select-sm" form="update-request-@request.Id">
                                    <option value="Pending" selected="@(request.Status == "Pending" ? "selected" : null)">Pending</option>
                                    <option value="In Review" selected="@(request.Status == "In Review" ? "selected" : null)">In Review</option>
                                    <option value="Completed" selected="@(request.Status == "Completed" ? "selected" : null)">Completed</option>
                                </select>
                            </td>
                            <td>@request.SubmittedOn.ToString("MMM dd, yyyy")</td>
                            <td>
                                <div class="d-flex flex-column gap-2">
                                    <form id="update-request-@request.Id" asp-action="UpdateRequest" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="requestId" value="@request.Id" />
                                        <button type="submit" class="btn btn-sm btn-civic">Save</button>
                                    </form>
                                @if (request.Status == "Completed")
                                {
                                    <form asp-action="DeleteRequest" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="requestId" value="@request.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this completed request?');">Delete</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small">Complete first to delete</span>
                                }
                                </div>
                            </td>
                        }
                        else
                        {
                            <td><span class="priority-badge priority-badge--@request.Priority.ToLowerInvariant()">@request.Priority</span></td>
                            <td><span class="status-badge">@request.Status</span></td>
                            <td>@request.SubmittedOn.ToString("MMM dd, yyyy")</td>
                        }
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </article>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
