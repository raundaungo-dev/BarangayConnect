@model BarangayConnect.Models.RequestsPageViewModel
@{
    ViewData["Title"] = "Service Requests";
}

<section class="page-heading page-heading--split">
    <div>
        <p class="eyebrow">Request Desk</p>
        <h1>Track resident concerns and follow-up requests with clearer prioritization</h1>
        <p>This workflow stores resident-service links together with priority and status so follow-up is easier for staff and residents.</p>
    </div>
    <div class="page-heading__card">
        <strong>@Model.Requests.Count</strong>
        <span>requests in the current log</span>
    </div>
</section>

@if (TempData["StatusMessage"] is string message)
{
    <div class="alert alert-success shadow-sm">@message</div>
}

<section class="form-layout">
    <article class="panel-card">
        <div class="panel-header">
            <h2>Submit Request</h2>
            <span class="badge-soft">Case intake</span>
        </div>
        <form asp-action="Requests" method="post" class="data-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="field-grid">
                <div>
                    <label asp-for="NewRequest.ResidentId"></label>
                    <select asp-for="NewRequest.ResidentId" asp-items="Model.ResidentOptions" class="form-select">
                        <option value="">Select resident</option>
                    </select>
                    <span asp-validation-for="NewRequest.ResidentId" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="NewRequest.ServiceId"></label>
                    <select asp-for="NewRequest.ServiceId" asp-items="Model.ServiceOptions" class="form-select">
                        <option value="">Select service</option>
                    </select>
                    <span asp-validation-for="NewRequest.ServiceId" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="NewRequest.Priority"></label>
                    <select asp-for="NewRequest.Priority" class="form-select">
                        <option>Normal</option>
                        <option>High</option>
                        <option>Urgent</option>
                    </select>
                    <span asp-validation-for="NewRequest.Priority" class="text-danger"></span>
                </div>
                <div class="full-span">
                    <label asp-for="NewRequest.Description"></label>
                    <textarea asp-for="NewRequest.Description" class="form-control" rows="4" placeholder="Describe the request clearly, including deadline or context if needed."></textarea>
                    <span asp-validation-for="NewRequest.Description" class="text-danger"></span>
                </div>
            </div>
            <button type="submit" class="btn btn-civic">Submit Request</button>
        </form>
    </article>

    <article class="panel-card">
        <div class="panel-header">
            <h2>Priority Guide</h2>
            <span class="badge-soft">Helpful feature</span>
        </div>
        <div class="info-list">
            <div><strong>Normal:</strong> Standard service follow-up without a strict deadline.</div>
            <div><strong>High:</strong> Important request that should be reviewed earlier than the regular queue.</div>
            <div><strong>Urgent:</strong> Time-sensitive concern that affects an immediate school, work, or legal requirement.</div>
        </div>
    </article>

    <article class="panel-card panel-card-wide">
        <div class="panel-header">
            <h2>Request Log</h2>
            <span class="badge-soft">@Model.Requests.Count listed</span>
        </div>
        <div class="filter-control filter-control--inline">
            <input type="search" class="form-control" placeholder="Search by resident, service, priority, or status..." data-filter-input="#request-table" />
        </div>
        <div class="table-shell">
            <table id="request-table" class="table civic-table">
                <thead>
                    <tr>
                        <th>Resident</th>
                        <th>Service</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Submitted</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var request in Model.Requests)
                {
                    <tr data-filter-item data-filter-text="@($"{request.ResidentName} {request.ServiceName} {request.Priority} {request.Status} {request.SubmittedOn:MMM dd yyyy}")">
                        <td>@request.ResidentName</td>
                        <td>@request.ServiceName</td>
                        <td><span class="priority-badge priority-badge--@request.Priority.ToLowerInvariant()">@request.Priority</span></td>
                        <td><span class="status-badge">@request.Status</span></td>
                        <td>@request.SubmittedOn.ToString("MMM dd, yyyy")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </article>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
