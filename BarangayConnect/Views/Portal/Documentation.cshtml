@model BarangayConnect.Models.SystemDocumentationViewModel
@{
    ViewData["Title"] = "System Documentation";
}

<section class="page-heading page-heading--split">
    <div>
        <p class="eyebrow">Project Documentation</p>
        <h1>System features, diagrams, screenshots, ERD, table reference, and SQL statement guide</h1>
        <p>This page presents the complete website feature overview together with the database design and SQL operations used by the application.</p>
    </div>
    <div class="page-heading__card">
        <strong>Complete</strong>
        <span>submission-ready project documentation</span>
    </div>
</section>

<section class="feature-band">
@foreach (var feature in Model.Features)
{
    <article class="feature-card">
        <span class="feature-icon">FC</span>
        <h2>@feature.Title</h2>
        <p>@feature.Description</p>
        <a class="text-link" href="@feature.Route">Open module</a>
    </article>
}
</section>

<section class="panel-card documentation-section">
    <div class="panel-header">
        <h2>System Workflow Diagram</h2>
        <span class="badge-soft">Clear diagram</span>
    </div>
    <div class="workflow-diagram">
        <div class="workflow-node">Resident opens portal</div>
        <div class="workflow-arrow">&rarr;</div>
        <div class="workflow-node">Checks announcements or services</div>
        <div class="workflow-arrow">&rarr;</div>
        <div class="workflow-node">Registers resident record</div>
        <div class="workflow-arrow">&rarr;</div>
        <div class="workflow-node">Schedules appointment or submits request</div>
        <div class="workflow-arrow">&rarr;</div>
        <div class="workflow-node">Data stored in SQLite database</div>
    </div>
</section>

<section class="panel-card documentation-section">
    <div class="panel-header">
        <h2>Screen Previews</h2>
        <span class="badge-soft">Live screenshots</span>
    </div>
    <div class="preview-grid">
    @foreach (var preview in Model.Previews)
    {
        <article class="preview-card">
            <div class="preview-frame">
                <iframe src="@preview.Route" title="@preview.Title" loading="lazy"></iframe>
            </div>
            <h3>@preview.Title</h3>
            <p>@preview.Description</p>
        </article>
    }
    </div>
</section>

<section class="panel-card documentation-section">
    <div class="panel-header">
        <h2>Final Entity Relationship Diagram</h2>
        <span class="badge-soft">Large and clear ERD</span>
    </div>
    <div class="erd-links">
        <a class="btn btn-civic" href="@Model.ErdPdfPath" target="_blank" rel="noopener">Open ERD PDF</a>
        <a class="btn btn-outline-civic" href="@Model.ErdImagePath" target="_blank" rel="noopener">Open ERD JPG</a>
    </div>
    <div class="erd-frame">
        <img src="@Model.ErdImagePath" alt="BarangayConnect Entity Relationship Diagram" class="img-fluid" />
    </div>
</section>

<section class="panel-card documentation-section">
    <div class="panel-header">
        <h2>Entity Reference Document</h2>
        <span class="badge-soft">Formatted tables</span>
    </div>
    <div class="stack-grid">
    @foreach (var table in Model.Tables)
    {
        <article class="panel-card panel-card--nested">
            <div class="panel-header">
                <div>
                    <h3>@table.TableName</h3>
                    <p>@table.Summary</p>
                </div>
                <span class="badge-soft">@table.Columns.Count columns</span>
            </div>
            <div class="table-shell">
                <table class="table civic-table documentation-table">
                    <thead>
                        <tr>
                            <th>Attribute</th>
                            <th>Data Type</th>
                            <th>Description</th>
                            <th>Key</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var column in table.Columns)
                    {
                        <tr>
                            <td>@column.Name</td>
                            <td>@column.DataType</td>
                            <td>@column.Description</td>
                            <td>@(string.IsNullOrWhiteSpace(column.KeyType) ? "—" : column.KeyType)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </article>
    }
    </div>
</section>

<section class="panel-card documentation-section">
    <div class="panel-header">
        <h2>SQL Statements Used by the Application</h2>
        <span class="badge-soft">Retrieve and update operations</span>
    </div>
    <div class="sql-reference-list">
    @foreach (var statement in Model.SqlStatements)
    {
        <article class="sql-card">
            <div class="panel-header">
                <div>
                    <h3>@statement.Label</h3>
                    <p>@statement.Category</p>
                </div>
                <span class="badge-soft">@statement.Category</span>
            </div>
            <pre class="sql-block"><code>@statement.Sql</code></pre>
        </article>
    }
    </div>
</section>
