@model BarangayConnect.Models.DashboardViewModel
@{
    ViewData["Title"] = "Banay-Banay Dashboard";
}

<section class="hero-panel hero-panel--expanded dashboard-hero">
    <div class="hero-copy-block">
        <p class="eyebrow">Official Communications and Services</p>
        <h1>Welcome, @Model.DisplayName.</h1>
        <p class="hero-copy">
            Banay-Banay Comms Network gives residents and barangay staff a secure portal for announcements,
            appointments, service requests, and official service information.
        </p>
        <div class="hero-actions">
            <a class="btn btn-civic" asp-controller="Portal" asp-action="Announcements">View Announcements</a>
            <a class="btn btn-outline-civic" asp-controller="Portal" asp-action="Services">Browse Services</a>
        </div>
    </div>

    <aside class="hero-card hero-card--spotlight">
        <div class="status-kicker">Barangay Banay-Banay Operations Desk</div>
        <h2>@(Model.IsAdmin ? "Admin access is active" : "Resident access is active")</h2>
        <div class="mini-stat-list">
            <div>
                <span>Account Type</span>
                <strong>@(Model.IsAdmin ? "Administrator" : "Resident User")</strong>
            </div>
            <div>
                <span>Announcement Access</span>
                <strong>Available to all accounts</strong>
            </div>
            <div>
                <span>Primary Hotline</span>
                <strong>(02) 8123-4567</strong>
            </div>
        </div>
        <div class="notice-card">
            <h3>Portal Reminder</h3>
            <p>@(Model.IsAdmin ? "Admin accounts can review appointments, resident information, requests, and add services." : "Resident accounts can only view their own appointments and requests, while services and announcements remain visible.")</p>
        </div>
    </aside>
</section>

@if (Model.IsAdmin)
{
    <section class="stats-grid dashboard-stats">
        <article class="stat-card stat-card--emerald">
            <span>Residents</span>
            <strong>@Model.ResidentCount</strong>
            <p>Registered community members in the local directory.</p>
        </article>
        <article class="stat-card stat-card--gold">
            <span>Appointments</span>
            <strong>@Model.AppointmentCount</strong>
            <p>Scheduled service visits currently on record.</p>
        </article>
        <article class="stat-card stat-card--teal">
            <span>Pending Requests</span>
            <strong>@Model.PendingRequestCount</strong>
            <p>Open resident concerns and non-walk-in transactions.</p>
        </article>
        <article class="stat-card stat-card--plum">
            <span>Announcements</span>
            <strong>@Model.ActiveAnnouncementCount</strong>
            <p>Live updates published for the community.</p>
        </article>
    </section>
}

<section class="content-grid dashboard-grid">
    <article class="panel-card">
        <div class="panel-header">
            <h2>Recent Announcements</h2>
            <a asp-controller="Portal" asp-action="Announcements">View all</a>
        </div>
        @foreach (var item in Model.RecentAnnouncements)
        {
            <div class="feed-item">
                <p class="feed-meta">@item.Category &middot; @item.PublishedOn.ToString("MMMM dd, yyyy")</p>
                <h3>@item.Title</h3>
                <p>@item.Summary</p>
                <span class="badge-soft">@item.Audience</span>
            </div>
        }
    </article>

    <article class="panel-card">
        <div class="panel-header">
            <h2>@(Model.IsAdmin ? "Admin Quick Guide" : "Resident Quick Guide")</h2>
            <span class="badge-soft">Access rules</span>
        </div>
        <div class="timeline-list">
            @if (Model.IsAdmin)
            {
                <div><strong>Step 1:</strong> Monitor public announcements for all users.</div>
                <div><strong>Step 2:</strong> Review resident records, all appointments, and all service requests.</div>
                <div><strong>Step 3:</strong> Add or update available services from the service catalog page.</div>
            }
            else
            {
                <div><strong>Step 1:</strong> Check announcements and available services.</div>
                <div><strong>Step 2:</strong> Review only your own appointments and request log.</div>
                <div><strong>Step 3:</strong> Register your resident profile if your account is not yet linked.</div>
            }
        </div>
    </article>

    @if (Model.IsAdmin)
    {
        <article class="panel-card">
            <div class="panel-header">
                <h2>Upcoming Appointments</h2>
                <a asp-controller="Portal" asp-action="Appointments">Manage</a>
            </div>
            @foreach (var item in Model.UpcomingAppointments)
            {
                <div class="feed-item">
                    <p class="feed-meta">@item.AppointmentDate.ToString("MMMM dd, yyyy") &middot; @item.TimeSlot</p>
                    <h3>@item.ResidentName</h3>
                    <p>@item.ServiceName</p>
                    <span class="badge-soft">@item.Status</span>
                </div>
            }
        </article>

        <article class="panel-card panel-card-wide">
            <div class="panel-header">
                <h2>Latest Service Requests</h2>
                <a asp-controller="Portal" asp-action="Requests">Open request desk</a>
            </div>
            <div class="table-shell">
                <table class="table civic-table">
                    <thead>
                        <tr>
                            <th>Resident</th>
                            <th>Service</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th>Submitted</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.LatestRequests)
                    {
                        <tr>
                            <td>@item.ResidentName</td>
                            <td>@item.ServiceName</td>
                            <td><span class="priority-badge priority-badge--@item.Priority.ToLowerInvariant()">@item.Priority</span></td>
                            <td>@item.Status</td>
                            <td>@item.SubmittedOn.ToString("MMM dd, yyyy")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </article>
    }
</section>
