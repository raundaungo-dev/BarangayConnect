@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Banay-Banay Comms Network</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@600;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BarangayConnect.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var isLoggedIn = Context.Session.GetInt32("AccountId").HasValue;
        var isAdmin = string.Equals(Context.Session.GetString("AccountRole"), "Admin", StringComparison.OrdinalIgnoreCase);
    }
    <div class="utility-strip">
        <div class="container utility-strip__inner">
            <div class="utility-pill">Official barangay communications network</div>
            <div class="utility-links">
                <span>Barangay Banay-Banay, Cabuyao</span>
                <span>Citizen Help Desk: (02) 8123-4567</span>
            </div>
        </div>
    </div>

    <header class="site-header">
        <div class="container">
            <nav class="navbar navbar-expand-lg navbar-dark civic-nav">
                <a class="navbar-brand brand-lockup" asp-area="" asp-controller="Portal" asp-action="Index">
                    <img src="~/images/barangayconnect-logo.svg" alt="Banay-Banay Comms Network Logo" class="brand-logo" />
                    <span>
                        <strong>Banay-Banay Comms Network</strong>
                        <small>Barangay Banay-Banay, Cabuyao</small>
                    </span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    @if (isLoggedIn)
                    {
                        <ul class="navbar-nav ms-auto align-items-lg-center">
                            <li class="nav-item"><a class="nav-link" asp-controller="Portal" asp-action="Index">Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Portal" asp-action="Announcements">Announcements</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Portal" asp-action="Residents">Residents</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Portal" asp-action="Services">Services</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Portal" asp-action="Appointments">Appointments</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Portal" asp-action="Requests">Requests</a></li>
                            @if (isAdmin)
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Portal" asp-action="Documentation">Documentation</a></li>
                            }
                            <li class="nav-item"><a class="nav-link" asp-controller="Portal" asp-action="Logout" data-confirm-action="true" data-confirm-title="Log out of your account?" data-confirm-message="Your current session will end and you will be returned to the login page." data-confirm-button="Log Out">Logout</a></li>
                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav ms-auto align-items-lg-center">
                            <li class="nav-item"><a class="nav-link" asp-controller="Portal" asp-action="Login">Login</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Portal" asp-action="Register">Sign Up</a></li>
                        </ul>
                    }
                </div>
            </nav>
        </div>
    </header>

    <div class="container app-shell">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <div class="modal-card-backdrop" id="confirmation-modal" hidden>
        <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="confirmation-modal-title">
            <div class="modal-card__badge" id="confirmation-modal-badge">Please Confirm</div>
            <h2 id="confirmation-modal-title">Are you sure?</h2>
            <p id="confirmation-modal-message">Please confirm that you want to continue with this action.</p>
            <div class="modal-card__actions">
                <button type="button" class="btn btn-outline-civic" data-confirm-cancel="true">Cancel</button>
                <button type="button" class="btn btn-civic" data-confirm-continue="true">Continue</button>
            </div>
        </div>
    </div>

    <footer class="site-footer">
        <div class="container footer-card">
            <div class="footer-brand">
                <img src="~/images/barangayconnect-logo.svg" alt="Banay-Banay Comms Network Logo" class="footer-logo" />
                <div>
                    <strong>Banay-Banay Comms Network</strong>
                    <p>Government-style communications, resident services, and local coordination for Barangay Banay-Banay, Cabuyao.</p>
                </div>
            </div>
            <div class="footer-grid">
                <div>
                    <h3>Barangay Services</h3>
                    <p>Announcements, appointments, and service tracking organized in one official community platform.</p>
                </div>
                <div>
                    <h3>Official Contact</h3>
                    <p>(02) 8123-4567<br />support@banaybanay-cabuyao.gov.local</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
