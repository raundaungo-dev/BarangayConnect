<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BarangayConnect</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BarangayConnect.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="container">
            <nav class="navbar navbar-expand-lg navbar-dark civic-nav">
                <a class="navbar-brand brand-lockup" asp-area="" asp-controller="Portal" asp-action="Index">
                    <span class="brand-badge">BC</span>
                    <span>
                        <strong>BarangayConnect</strong>
                        <small>Resident Services Portal</small>
                    </span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item"><a class="nav-link" asp-controller="Portal" asp-action="Index">Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Portal" asp-action="Announcements">Announcements</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Portal" asp-action="Residents">Residents</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Portal" asp-action="Services">Services</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Portal" asp-action="Appointments">Appointments</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Portal" asp-action="Requests">Requests</a></li>
                    </ul>
                </div>
            </nav>
        </div>
    </header>
    <div class="container app-shell">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="container">
            <div>
                <strong>BarangayConnect</strong>
                <p>ASP.NET Core MVC + SQLite institutional website for IT114L project submission.</p>
            </div>
            <div class="footer-meta">
                <span>&copy; 2026 BarangayConnect</span>
                <span>Embedded local database</span>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
